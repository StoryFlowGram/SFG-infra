# ==============================================================================
# GLOBAL SETTINGS
# ==============================================================================
GLOBAL_SECRET_KEY=your_super_secret_key_here
GLOBAL_JWT_SECRET=your_jwt_secret_hex_string_here
JWT_ALGORITHM=HS256

# ==============================================================================
# IDENTITY SERVICE
# ==============================================================================
IDENTITY_DB_USER=identity_user
IDENTITY_DB_PASSWORD=your_identity_db_password
IDENTITY_DB_NAME=identity-db

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_SECRET_CLIENT_ID=your_google_client_secret


GOOGLE_REDIRECT_URI=https://your_domain.com/api/v1/auth/callback/google
GOOGLE_LINK_REDIRECT_URI=https://your_domain.com/api/v1/auth/callback/link-google

IDENTITY_REDIS_HOST=book-redis
IDENTITY_REDIS_URL=redis://book-redis:6379/0

# ==============================================================================
# BOOK SERVICE & MINIO
# ==============================================================================
BOOK_DB_USER=book_user
BOOK_DB_PASSWORD=your_book_db_password
BOOK_DB_NAME=book-db

TASKIQ_BROKER_URL=redis://book-redis:6379/0
REDIS_URL=redis://book-redis:6379/0

MINIO_ROOT_USER=sfg_admin
MINIO_ROOT_PASSWORD=your_secure_minio_password
S3_BUCKET_NAME=chapters
S3_ENDPOINT_URL=http://minio:9000
S3_REGION_NAME=us-east-1

# ==============================================================================
# LEARNING SERVICE
# ==============================================================================
LEARN_DB_USER=learn_user
LEARN_DB_PASSWORD=your_learn_db_password
LEARN_DB_NAME=learn-db

# ==============================================================================
# READER SERVICE
# ==============================================================================
READER_DB_USER=reader_user
READER_DB_PASSWORD=your_reader_db_password
READER_DB_NAME=reader-db
READER_BOOK_SERVICE_URL=http://book-service:8000

# ==============================================================================
# BOT SERVICE
# ==============================================================================
TELEGRAM_ADMIN_ID=your_telegram_admin_id
BOT_TOKEN=1234567890:YOUR_BOT_TOKEN_HERE
WEB_APP_URL=https://your_domain.com

# ==============================================================================
# FRONTEND
# ==============================================================================
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_API_URL=/api/v1
VITE_BACKEND_HOST=https://your_domain.com